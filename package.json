{
  "name": "workspace",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:backend": "node --test backend/lib/*.test.js backend/lib/*.node.js",
    "test:app": "npm --prefix app run test",
    "lint:app": "npm --prefix app run lint -- --max-warnings=0",
    "build:app": "npm --prefix app run build",
    "test:e2e": "bash scripts/e2e.sh",
    "test:e2e:smoke": "bash scripts/e2e.sh tests/e2e/smoke.spec.ts",
    "test:e2e:nav": "bash scripts/e2e.sh tests/e2e/form-navigation.spec.ts",
    "test:e2e:critical": "bash scripts/run-critical-e2e.sh",
    "smoke:production": "node scripts/production-smoke.mjs"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [],
