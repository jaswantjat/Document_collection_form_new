# OpenRouter API Key for AI extraction
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required in production to protect the dashboard
DASHBOARD_PASSWORD=change_me

# Optional. Railway will default to /data when a volume is mounted.
# DATA_DIR=/data

# Optional. Preferred webhook target for form submit/update notifications.
# When set, backend submit events will send the rich Spanish payload here.
# ELTEX_FORM_NOTIFICATIONS_WEBHOOK_URL=https://primary-production-903a.up.railway.app/webhook/your-webhook-id

# Optional. Public base URL used to build the direct customer form link in notifications.
# Defaults to https://documentos.eltex.es when omitted.
# ELTEX_PUBLIC_FORM_BASE_URL=https://documentos.eltex.es

# Optional. Falls back to ELTEX_DOCFLOW_WEBHOOK_SECRET when omitted.
# ELTEX_FORM_NOTIFICATIONS_WEBHOOK_SECRET=change_me

# Optional. Leave unset in production unless you explicitly want demo records.
# SEED_SAMPLE_DATA=false

# Port configuration (Railway will set PORT automatically)
PORT=3001
