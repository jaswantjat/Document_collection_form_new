# OpenRouter API key for AI extraction.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Required in production to protect the dashboard.
DASHBOARD_PASSWORD=change_me

# Optional DocFlow webhook integration.
# Use real values only in Railway environment variables, never in this file.
ELTEX_DOCFLOW_WEBHOOK_URL=https://example.invalid/docflow
ELTEX_DOCFLOW_WEBHOOK_SECRET=change_me

# Optional Stirling PDF conversion service.
STIRLING_PDF_URL=https://example.invalid/api/v1/convert/pdf/img
STIRLING_PDF_API_KEY=change_me

# Optional autocropper service URL.
AUTOCROPPER_URL=http://localhost:5001

# Optional. Railway will default to /data when a volume is mounted.
# DATA_DIR=/data

# Optional. Leave unset in production unless you explicitly want demo records.
# SEED_SAMPLE_DATA=false

# Optional. Railway deployments default to one trusted proxy hop.
# TRUST_PROXY=1

# Port configuration (Railway will set PORT automatically)
PORT=3001
